# =============================================================================
# .gitignore — Files and directories excluded from version control
# =============================================================================

# ---------------------------------------------------------------------------
# SECRETS & ENVIRONMENT
# ---------------------------------------------------------------------------
# The .env file contains database passwords, JWT secrets, and other
# sensitive configuration. Only .env.example (with placeholder values)
# should be committed.
# ---------------------------------------------------------------------------
.env
*.env.local

# ---------------------------------------------------------------------------
# PYTHON
# ---------------------------------------------------------------------------
# Byte-compiled files, virtual environments, and build artifacts
# generated by Python tooling.
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# IDE / EDITOR
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ---------------------------------------------------------------------------
# DOCKER
# ---------------------------------------------------------------------------
# Docker volume data should not be committed.
# ---------------------------------------------------------------------------
pgdata/

# ---------------------------------------------------------------------------
# TESTING & COVERAGE
# ---------------------------------------------------------------------------
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
