# =============================================================================
# .env.example — Template for Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# This file is safe to commit to version control.
# The actual .env file should NEVER be committed.
# =============================================================================

# Database (async driver for FastAPI, sync driver for Alembic)
DATABASE_URL=postgresql+asyncpg://energy_user:YOUR_PASSWORD@db:5432/energy_platform
DATABASE_URL_SYNC=postgresql+psycopg2://energy_user:YOUR_PASSWORD@db:5432/energy_platform

# JWT Authentication
JWT_SECRET_KEY=CHANGE-ME-TO-A-RANDOM-STRING-AT-LEAST-32-CHARS
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Application
APP_NAME=AI Energy Optimization Platform
DEBUG=false
LOG_LEVEL=info

# CORS (Phase 1)
# Comma-separated list of allowed origins, or * to allow all (dev only)
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Rate Limiting (Phase 1)
RATE_LIMIT_PER_MINUTE=100

# Redis (Phase 2)
REDIS_URL=redis://redis:6379/0

# Email / SendGrid (Phase 2 — Notifications)
# Get your API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
FROM_EMAIL=alerts@energyplatform.io

# Weather API (Phase 3 — AI Forecasting)
# Get your API key at https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# Stripe (Phase 9 — P2P Energy Trading)
# Get your keys at https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Geocoding (Phase 9 — Neighbor Proximity Matching)
# Used to convert addresses to lat/lng and filter offers by distance
GEOCODING_API_KEY=
